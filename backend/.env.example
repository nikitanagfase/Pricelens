# ── Database ──────────────────────────────────────────
# Local dev default: SQLite (zero setup, works out of the box)
# Production: swap to your PostgreSQL URL, e.g.
# postgresql://user:password@localhost:5432/pricelens
DATABASE_URL=sqlite:///./pricelens.db

# ── Redis (price-cache) ───────────────────────────────
# Local dev default: leave as-is. If Redis isn't running,
# the app automatically falls back to an in-memory cache.
REDIS_URL=redis://localhost:6379/0

# ── JWT Auth ──────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Ignav Flight Fares API ────────────────────────────
# Get free key (1,000 free requests, no card) at https://ignav.com
# Leave BLANK to run in MOCK MODE (realistic generated data,
# clearly labeled, zero API key required — good for first run)
IGNAV_API_KEY=

# ── Anthropic (AI Assistant — optional bonus module) ──
ANTHROPIC_API_KEY=

# ── Firebase (push notifications — optional) ──────────
FIREBASE_SERVER_KEY=

# ── CORS ──────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173